FROM python:3.11-slim
RUN apt-get update && apt-get install -y --no-install-recommends ffmpeg libsndfile1 \
    && rm -rf /var/lib/apt/lists/*
# torch (CUDA) provides the nvidia cudnn/cublas wheels CTranslate2 needs on GPU
RUN pip install --no-cache-dir torch "transformers[torch]" faster-whisper ctranslate2 \
    nvidia-cublas-cu12 "nvidia-cudnn-cu12==9.*" \
    fastapi uvicorn python-multipart
ENV LD_LIBRARY_PATH=/usr/local/lib/python3.11/site-packages/nvidia/cudnn/lib:/usr/local/lib/python3.11/site-packages/nvidia/cublas/lib
WORKDIR /app
